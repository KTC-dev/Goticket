{
  "version": 2,
  "builds": [
    {
      "src": "build/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/js/(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000"
      }
    },
    {
      "src": "/static/css/(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000"
      }
    }
  ]
}